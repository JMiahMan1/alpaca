FROM python:3.11-slim
WORKDIR /app
RUN apt-get update && apt-get install -y --no-install-recommends docker-cli curl && rm -rf /var/lib/apt/lists/*
RUN pip install fastapi uvicorn httpx psutil
COPY alpaca-proxy.py .
COPY alpaca-puller.py .
COPY benchmark-configs.py .
CMD ["python", "alpaca-proxy.py"]
